{
  "base_url": "http://localhost:8000",
  "auth_header_format": "Bearer <access_token>",
  "notes": [
    "All /api/v1/cac/* and /api/v1/bpp/* endpoints require Authorization header.",
    "For multipart endpoints, do not send JSON body; use form-data with keys exactly as documented.",
    "Use register/login response access_token for subsequent requests.",
    "CAC workflow tests: run Create CAC Company first, then CAC NEW or CAC RENEWAL blocks in order."
  ],
  "endpoints": [
    {
      "name": "List Workflow Templates",
      "method": "GET",
      "uri": "/api/v1/workflow/templates",
      "headers": {
        "Authorization": "Bearer <access_token>"
      },
      "json_payload": null
    },
    {
      "name": "Get Workflow Template By Type+Mode",
      "method": "GET",
      "uri": "/api/v1/workflow/templates/FIRS/RENEWAL",
      "headers": {
        "Authorization": "Bearer <access_token>"
      },
      "json_payload": null
    },
    {
      "name": "List Company Documents (all uploads)",
      "method": "GET",
      "uri": "/api/v1/companies/{company_id}/documents",
      "headers": {
        "Authorization": "Bearer <access_token>"
      },
      "json_payload": null
    },
    {
      "name": "List Company Documents By doc_type",
      "method": "GET",
      "uri": "/api/v1/companies/{company_id}/documents?doc_type=CAC_CERTIFICATE",
      "headers": {
        "Authorization": "Bearer <access_token>"
      },
      "json_payload": null
    },
    {
      "name": "Reuse Document For Another Compliance",
      "method": "POST",
      "uri": "/api/v1/companies/{company_id}/documents/reuse",
      "headers": {
        "Authorization": "Bearer <access_token>",
        "Content-Type": "application/json"
      },
      "json_payload": {
        "document_id": "<existing-document-uuid>",
        "compliance_type": "FIRS"
      }
    },
    {
      "name": "Get Company Workflow Progress (all workflows)",
      "method": "GET",
      "uri": "/api/v1/workflow/companies/{company_id}/progress",
      "headers": {
        "Authorization": "Bearer <access_token>"
      },
      "json_payload": null
    },
    {
      "name": "Start FIRS Renewal Workflow",
      "method": "POST",
      "uri": "/api/v1/workflow/FIRS/RENEWAL/companies/{company_id}/start",
      "headers": {
        "Authorization": "Bearer <access_token>"
      },
      "json_payload": null
    },
    {
      "name": "Complete Workflow Step",
      "method": "POST",
      "uri": "/api/v1/workflow/FIRS/RENEWAL/companies/{company_id}/steps/1/complete",
      "headers": {
        "Authorization": "Bearer <access_token>",
        "Content-Type": "application/json"
      },
      "json_payload": {
        "step_name": "Provide yearly financial records",
        "data": {}
      }
    },
    {
      "name": "Upload Workflow Document",
      "method": "POST",
      "uri": "/api/v1/workflow/FIRS/companies/{company_id}/documents",
      "headers": {
        "Authorization": "Bearer <access_token>"
      },
      "multipart_form_data": {
        "doc_type": "AUDITED_FINANCIAL_STATEMENTS",
        "file": "<select-file-in-postman>"
      },
      "json_payload": null
    },
    {
      "name": "Add Workflow Output",
      "method": "POST",
      "uri": "/api/v1/workflow/FIRS/RENEWAL/companies/{company_id}/outputs",
