{
  "info": {
    "name": "Smart Trybe Compliance API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "access_token", "value": "" },
    { "key": "company_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.access_token) pm.collectionVariables.set('access_token', j.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"you@example.com\",\n  \"password\": \"yourpassword8charsmin\",\n  \"full_name\": \"Your Name\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/register"
          }
        },
        {
          "name": "POST login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.access_token) pm.collectionVariables.set('access_token', j.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"you@example.com\",\n  \"password\": \"yourpassword8charsmin\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login"
          }
        },
        {
          "name": "GET me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/v1/auth/me"
          }
        }
      ]
    },
    {
      "name": "CAC",
      "item": [
        {
          "name": "POST companies",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.id) pm.collectionVariables.set('company_id', j.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Nigeria Ltd\",\n  \"rc_number\": \"RC-123456\",\n  \"tin\": \"12345678-0001\",\n  \"address\": \"Victoria Island, Lagos\"\n}"
            },
            "url": "{{base_url}}/api/v1/cac/companies"
          }
        },
        {
          "name": "GET companies",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/v1/cac/companies"
          }
        },
        {
          "name": "GET company by id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/v1/cac/companies/{{company_id}}"
          }
        },
        {
          "name": "PATCH company",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Nigeria Ltd (updated)\",\n  \"address\": \"Ikoyi, Lagos\"\n}"
            },
            "url": "{{base_url}}/api/v1/cac/companies/{{company_id}}"
          }
        },
        {
          "name": "GET CAC registry",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/v1/cac/companies/{{company_id}}/registry"
          }
        },
        {
          "name": "PUT CAC registry",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"COMPLETED\",\n  \"expiry_date\": \"2027-12-31\"\n}"
            },
            "url": "{{base_url}}/api/v1/cac/companies/{{company_id}}/registry"
          }
        },
        {
          "name": "POST CAC document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "doc_type", "value": "CAC_CERTIFICATE", "type": "text" },
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": "{{base_url}}/api/v1/cac/companies/{{company_id}}/documents"
          }
        }
      ]
    },
    {
      "name": "BPP Federal",
      "item": [
        {
          "name": "GET registry",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/v1/bpp/federal/companies/{{company_id}}/registry"
          }
        },
        {
          "name": "PUT registry",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PENDING\",\n  \"expiry_date\": null\n}"
            },
            "url": "{{base_url}}/api/v1/bpp/federal/companies/{{company_id}}/registry"
          }
        },
        {
          "name": "POST document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "doc_type", "value": "APPLICATION_FORM", "type": "text" },
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": "{{base_url}}/api/v1/bpp/federal/companies/{{company_id}}/documents"
          }
        }
      ]
    },
    {
      "name": "BPP State",
      "item": [
        {
          "name": "GET registry",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/v1/bpp/state/companies/{{company_id}}/registry"
          }
        },
        {
          "name": "PUT registry",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PENDING\",\n  \"expiry_date\": null\n}"
            },
            "url": "{{base_url}}/api/v1/bpp/state/companies/{{company_id}}/registry"
          }
        },
        {
          "name": "POST document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "doc_type", "value": "VENDOR_FORM", "type": "text" },
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": "{{base_url}}/api/v1/bpp/state/companies/{{company_id}}/documents"
          }
        }
      ]
    }
  ]
}
